{
  "files.exclude": {
    "**/*.aux": true,
    "**/*.bbl": true,
    "**/*.bcf": true,
    "**/*.blg": true,
    "**/*.fdb_latexmk": true,
    "**/*.fls": true,
    "**/*.lof": true,
    "**/*.log": true,
    "**/*.lot": true,
    "**/*.out": true,
    "**/*.run.xml": true,
    "**/*.synctex.gz": true,
    "**/*.toc": true,
    "**/*.glo": true,
    "**/*.glo-abr": true,
    "**/*.gls": true,
    "**/*.gls-abr": true,
    "**/*.glg": true,
    "**/*.glg-abr": true,
    "**/*.ist": true,
    "**/*.data.minted": true,
    "_minted*/": true
  },
  "latex-workshop.latex.autoBuild.run": "never",
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex",
      "command": "pdflatex",
      "args": [
        "-shell-escape",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    },
    {
      "name": "biber",
      "command": "biber",
      "args": ["%DOCFILE%"]
    },
    {
      "name": "makeglossaries",
      "command": "makeglossaries",
      "args": ["%DOCFILE%"]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "pdflatex -> biber -> makeglossaries -> pdflatex x2",
      "tools": ["pdflatex", "biber", "makeglossaries", "pdflatex", "pdflatex"]
    },
    {
      "name": "pdflatex x2",
      "tools": ["pdflatex", "pdflatex"]
    }
  ],
  "latex-workshop.latex.recipe.default": "pdflatex -> biber -> makeglossaries -> pdflatex x2",
  "latex-workshop.latex.rootFile.doNotPrompt": true,
  "latex-workshop.latex.search.rootFiles.include": [
    "Programmazione_di_Sistema.tex"
  ]
}
